{
  "name": "swarme-edge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute swarme-main --local --file=./migrations/0001_init.sql",
