# ============================================================
# Swarme — Environment Variables Template
# Copy to .env and fill in your values.
# ============================================================

# ─── Core API Keys (Required) ─────────────────────────────
# OpenAI — Used by the Worker for GPT-4o content generation (drafting step)
OPENAI_API_KEY=sk-...

# Perplexity — Used by the Worker for Sonar research API (SERP analysis + citations)
PERPLEXITY_API_KEY=pplx-...

# ─── Frontend Configuration ───────────────────────────────
# The deployed Cloudflare Worker URL that the Next.js dashboard calls.
# Example: https://swarme-api.<your-subdomain>.workers.dev
# or your custom domain: https://api.swarme.io
NEXT_PUBLIC_API_URL=https://swarme-api.<your-subdomain>.workers.dev

# ─── Stripe Billing (Phase 7) ────────────────────────────
# Stripe secret key for creating Checkout Sessions (billing endpoint)
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret (verify webhook signatures)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Optional: Future Phases ──────────────────────────────
# Anthropic — Claude 3.5 Sonnet fallback for reasoning tasks
# ANTHROPIC_API_KEY=sk-ant-...

# Hunter.io — Email lookup for outreach agent
# HUNTER_API_KEY=...

# Resend — Transactional email sending for outreach campaigns
# RESEND_API_KEY=re_...

# PostHog — CRO telemetry and A/B test tracking
# POSTHOG_API_KEY=phc_...

# ─── CMS Webhook (Per-Project, stored in KV) ─────────────
# These are set per-project via KV, not as global env vars.
# KV key: vault:project:{projectId}:cms_webhook_url
# KV key: vault:project:{projectId}:cms_api_key
# CMS_WEBHOOK_URL=https://your-cms.com/api/webhook
# CMS_API_KEY=...
